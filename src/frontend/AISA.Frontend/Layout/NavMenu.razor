@inject IStringLocalizer<App> L

<MudNavMenu>
    <MudText Typo="Typo.subtitle2" Class="px-4 mt-4 mb-2" Style="color: var(--mud-palette-text-secondary);">
        @L["Navigation"]
    </MudText>

    <MudNavLink Href="/"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Dashboard">
        @L["Dashboard"]
    </MudNavLink>

    <MudNavLink Href="/reviews"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.RateReview">
        @L["Reviews"]
    </MudNavLink>

    <MudNavLink Href="/settings"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Settings">
        @L["Settings"]
    </MudNavLink>

    <MudDivider Class="my-2" />

    <MudText Typo="Typo.subtitle2" Class="px-4 mt-2 mb-2" Style="color: var(--mud-palette-text-secondary);">
        @L["Plan"]
    </MudText>

    <MudNavLink Icon="@Icons.Material.Filled.Star" Disabled="true">
        @L["FreeTier"]
    </MudNavLink>
</MudNavMenu>
