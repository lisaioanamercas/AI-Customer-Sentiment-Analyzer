@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IState<AuthState> AuthState
@inject IDispatcher Dispatcher

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="1" Color="Color.Surface">
                <MudIconButton Icon="@Icons.Material.Filled.Menu"
                               Color="Color.Inherit"
                               Edge="Edge.Start"
                               OnClick="@ToggleDrawer" />
                <MudText Typo="Typo.h6" Class="ml-2">
                    <strong>AISA</strong> — Sentiment Analyzer
                </MudText>
                <MudSpacer />
                <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined" Class="mr-2">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                    @(AuthState.Value.FullName ?? "Utilizator")
                </MudChip>
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Color="Color.Inherit"
                               OnClick="HandleLogout" />
            </MudAppBar>

            <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
                <NavMenu />
            </MudDrawer>

            <MudMainContent Class="pa-4">
                @Body
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        @{
            Navigation.NavigateTo("/login", forceLoad: false);
        }
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _drawerOpen = true;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        // Trigger auth initialization from localStorage
        Dispatcher.Dispatch(new InitializeAuthAction());
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void HandleLogout()
    {
        Dispatcher.Dispatch(new LogoutAction());
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
