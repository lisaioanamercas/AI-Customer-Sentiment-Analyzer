@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IState<AuthState> AuthState
@inject IDispatcher Dispatcher
@inject IStringLocalizer<App> L
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="1" Color="Color.Surface">
                <MudIconButton Icon="@Icons.Material.Filled.Menu"
                               Color="Color.Inherit"
                               Edge="Edge.Start"
                               OnClick="@ToggleDrawer" />
                <MudText Typo="Typo.h6" Class="ml-2">
                    <strong>AISA</strong>
                </MudText>
                <MudSpacer />
                
                <!-- Language Toggle -->
                <MudMenu StartIcon="@Icons.Material.Filled.Language" Color="Color.Inherit" Label="@(CultureInfo.CurrentCulture.Name.StartsWith("ro") ? "RO" : "EN")" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" Dense="true" Class="mr-4">
                    <MudMenuItem OnClick='() => SwitchLanguage("en-US")'>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <span style="font-size: 1.2rem;">🇬🇧</span>
                            <MudText>English</MudText>
                        </MudStack>
                    </MudMenuItem>
                    <MudMenuItem OnClick='() => SwitchLanguage("ro-RO")'>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <span style="font-size: 1.2rem;">🇷🇴</span>
                            <MudText>Română</MudText>
                        </MudStack>
                    </MudMenuItem>
                </MudMenu>

                <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined" Class="mr-2">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                    @(AuthState.Value.FullName ?? L["Utilizator"])
                </MudChip>
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Color="Color.Inherit"
                               OnClick="HandleLogout" />
            </MudAppBar>

            <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
                <NavMenu />
            </MudDrawer>

            <MudMainContent Class="pa-4">
                @Body
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        @{
            Navigation.NavigateTo("/login", forceLoad: false);
        }
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#6366f1",
            Secondary = "#8b5cf6",
            Success = "#10b981",
            Error = "#ef4444",
            Warning = "#f59e0b",
            Info = "#3b82f6",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#6366f1",
            Secondary = "#8b5cf6",
            Success = "#10b981",
            Error = "#ef4444",
            Warning = "#f59e0b",
            Info = "#3b82f6",
            Background = "#0f172a",
            Surface = "#1e293b",
            AppbarBackground = "#1e293b",
            DrawerBackground = "#1e293b",
            TextPrimary = "#f1f5f9",
            TextSecondary = "#94a3b8",
        }
    };

    protected override void OnInitialized()
    {
        base.OnInitialized();
        // Trigger auth initialization from localStorage
        Dispatcher.Dispatch(new InitializeAuthAction());
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task SwitchLanguage(string culture)
    {
        if (CultureInfo.CurrentCulture.Name != culture)
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "aisa_culture", culture);
            Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
        }
    }

    private void HandleLogout()
    {
        Dispatcher.Dispatch(new LogoutAction());
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
