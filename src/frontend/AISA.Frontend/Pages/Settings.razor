@page "/settings"
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IStringLocalizer<App> L

<PageTitle>Settings — AISA</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" /> @L["Settings"]
</MudText>

<MudPaper Class="pa-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-3">@L["BusinessProfile"]</MudText>

    @if (_currentProfile is not null)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-3">
            Active profile: <strong>@_currentProfile.Name</strong>
            (@_currentProfile.SubscriptionTier · @_currentProfile.ReviewCount reviews)
        </MudAlert>
    }

    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_name"
                          Label="@L["Name"]"
                          Variant="Variant.Outlined"
                          Required="true" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_category" Label="@L["Category"]" Variant="Variant.Outlined">
                <MudSelectItem Value="@("Restaurant")">Restaurant</MudSelectItem>
                <MudSelectItem Value="@("Cafenea")">Cafe</MudSelectItem>
                <MudSelectItem Value="@("Clinică")">Clinic</MudSelectItem>
                <MudSelectItem Value="@("Hotel")">Hotel</MudSelectItem>
                <MudSelectItem Value="@("Magazin")">Shop</MudSelectItem>
                <MudSelectItem Value="@("Altele")">Other</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12">
            <MudTextField @bind-Value="_description"
                          Label="@L["Description"]"
                          Variant="Variant.Outlined"
                          Lines="2" />
        </MudItem>
        <MudItem xs="12">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveProfile"
                       Disabled="_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                @L["SaveProfile"]
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    [Inject] private IState<AuthState> AuthState { get; set; } = null!;
    [Inject] private IDispatcher Dispatcher { get; set; } = null!;
    [Inject] private IApiService ApiService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private string _name = string.Empty;
    private string? _description;
    private string? _category;
    private string? _address;
    private string? _googleMapsUrl;
    private string? _tripAdvisorUrl;
    private bool _saving;
    private BusinessProfileModel? _currentProfile;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.Value.BusinessProfileId.HasValue)
        {
            try
            {
                _currentProfile = await ApiService.GetBusinessProfileAsync(AuthState.Value.BusinessProfileId.Value);
                PopulateFields();
            }
            catch { }
        }
        else
        {
            // Try to fetch "my" profile if ID not in token
            try
            {
                _currentProfile = await ApiService.GetMyBusinessProfileAsync();
                PopulateFields();
            }
            catch { }
        }
    }

    private void PopulateFields()
    {
        if (_currentProfile is not null && string.IsNullOrEmpty(_name))
        {
            _name = _currentProfile.Name;
            _description = _currentProfile.Description;
            _category = _currentProfile.Category;
            _address = _currentProfile.Address;
            _googleMapsUrl = _currentProfile.GoogleMapsUrl;
            _tripAdvisorUrl = _currentProfile.TripAdvisorUrl;
        }
    }

    private async Task SaveProfile()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            Snackbar.Add("Numele afacerii este obligatoriu.", Severity.Warning);
            return;
        }

        _saving = true;

        try
        {
            BusinessProfileModel profile;
            
            if (_currentProfile is not null)
            {
                profile = await ApiService.UpdateBusinessProfileAsync(
                    _currentProfile.Id, _name, _description, _category, _address, _googleMapsUrl, _tripAdvisorUrl);
                Snackbar.Add("Profil actualizat cu succes!", Severity.Success);
            }
            else
            {
                profile = await ApiService.CreateBusinessProfileAsync(
                    _name, _description, _category, _address, _googleMapsUrl, _tripAdvisorUrl);
                Snackbar.Add("Profil creat cu succes!", Severity.Success);
            }

            _currentProfile = profile;
            // Update auth state if name changed
            Dispatcher.Dispatch(new InitializeAuthAction()); 
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Eroare: {ex.Message}", Severity.Error);
        }

        _saving = false;
    }
}
