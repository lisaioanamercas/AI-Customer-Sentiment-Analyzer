@page "/settings"
@implements IDisposable

<PageTitle>Settings — AISA</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" /> Business Profile Settings
</MudText>

<MudPaper Class="pa-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-3">Business Profile</MudText>

    @if (State.CurrentProfile is not null)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-3">
            Active profile: <strong>@State.CurrentProfile.Name</strong>
            (@State.CurrentProfile.SubscriptionTier · @State.CurrentProfile.ReviewCount reviews)
        </MudAlert>
    }

    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_name"
                          Label="Business Name"
                          Variant="Variant.Outlined"
                          Required="true" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_category" Label="Category" Variant="Variant.Outlined">
                <MudSelectItem Value="@("Restaurant")">Restaurant</MudSelectItem>
                <MudSelectItem Value="@("Cafenea")">Cafe</MudSelectItem>
                <MudSelectItem Value="@("Clinică")">Clinic</MudSelectItem>
                <MudSelectItem Value="@("Hotel")">Hotel</MudSelectItem>
                <MudSelectItem Value="@("Magazin")">Shop</MudSelectItem>
                <MudSelectItem Value="@("Altele")">Other</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12">
            <MudTextField @bind-Value="_description"
                          Label="Description"
                          Variant="Variant.Outlined"
                          Lines="2" />
        </MudItem>
        <MudItem xs="12">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveProfile"
                       Disabled="_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Save Profile
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    [Inject] private IApiService ApiService { get; set; } = null!;
    [Inject] private StateContainer State { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private string _name = string.Empty;
    private string? _description;
    private string? _category;
    private string? _address;
    private string? _googleMapsUrl;
    private string? _tripAdvisorUrl;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += OnStateChanged;

        // Dacă profilul nu e încă în State (ex: refresh direct pe /settings),
        // îl încărcăm direct de pe API fără să așteptăm MainLayout.
        if (State.CurrentProfile is null)
        {
            try
            {
                State.CurrentProfile = await ApiService.GetMyBusinessProfileAsync();
            }
            catch { /* ignorăm, formularul rămâne gol */ }
        }

        PopulateFields();
    }

    private void OnStateChanged()
    {
        PopulateFields();
        InvokeAsync(StateHasChanged); // forțăm re-renderul pe thread-ul UI
    }

    private void PopulateFields()
    {
        if (State.CurrentProfile is not null && string.IsNullOrEmpty(_name))
        {
            _name = State.CurrentProfile.Name;
            _description = State.CurrentProfile.Description;
            _category = State.CurrentProfile.Category;
            _address = State.CurrentProfile.Address;
            _googleMapsUrl = State.CurrentProfile.GoogleMapsUrl;
            _tripAdvisorUrl = State.CurrentProfile.TripAdvisorUrl;
        }
    }

    public void Dispose()
    {
        State.OnChange -= OnStateChanged;
    }

    private async Task SaveProfile()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            Snackbar.Add("Numele afacerii este obligatoriu.", Severity.Warning);
            return;
        }

        _saving = true;

        try
        {
            BusinessProfileModel profile;
            
            if (State.CurrentProfile is not null)
            {
                // Update existent
                profile = await ApiService.UpdateBusinessProfileAsync(
                    State.CurrentProfile.Id, _name, _description, _category, _address, _googleMapsUrl, _tripAdvisorUrl);
                Snackbar.Add("Profil actualizat cu succes!", Severity.Success);
            }
            else
            {
                // Creare nou (acum include si URL-urile)
                profile = await ApiService.CreateBusinessProfileAsync(
                    _name, _description, _category, _address, _googleMapsUrl, _tripAdvisorUrl);
                Snackbar.Add("Profil creat cu succes!", Severity.Success);
            }

            State.CurrentProfile = profile;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Eroare: {ex.Message}", Severity.Error);
        }

        _saving = false;
    }
}
