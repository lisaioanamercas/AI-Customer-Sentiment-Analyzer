@page "/reviews"

<PageTitle>Recenzii — AISA</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.RateReview" Class="mr-2" /> Inbox Recenzii
</MudText>

<!-- Scraper Control Panel -->
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-3">Configurare Scraping</MudText>
    <MudGrid>
        <MudItem xs="12" sm="3">
            <MudSelect @bind-Value="_source" Label="Sursa" Variant="Variant.Outlined">
                <MudSelectItem Value="@("Google")">Google Maps</MudSelectItem>
                <MudSelectItem Value="@("TripAdvisor")">TripAdvisor</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect @bind-Value="_sortBy" Label="Ordonează după" Variant="Variant.Outlined">
                <MudSelectItem Value="@("newest")">Cele mai noi</MudSelectItem>
                <MudSelectItem Value="@("relevant")">Cele mai relevante</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudNumericField @bind-Value="_maxCount" 
                             Label="Număr recenzii" 
                             Variant="Variant.Outlined" 
                             Min="1" Max="50" />
        </MudItem>
        <MudItem xs="12" sm="3" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.AutoFixHigh"
                       OnClick="RunScraper"
                       Disabled="_submitting">
                @if (_submitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Analizează
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<!-- Import Manual CSV Panel -->
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-3">Import Manual (CSV)</MudText>
    <MudGrid>
        <MudItem xs="12" sm="8" Class="d-flex align-center">
            <MudText Typo="Typo.body2" Class="mr-4">
                Poți importa manual recenzii folosind un fișier CSV cu coloanele: <b>Textul Recenziei, Nume Autor, Sursa, Data, Rating (1-5)</b>. 
            </MudText>
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="DownloadTemplate" StartIcon="@Icons.Material.Filled.Download">
                Descarcă Șablon
            </MudButton>
        </MudItem>
        <MudItem xs="12" sm="4" Class="d-flex align-end justify-end">
            <MudFileUpload T="IBrowserFile" FilesChanged="UploadCsv" Accept=".csv" Disabled="_uploading">
                <ActivatorContent>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               Disabled="_uploading">
                        @if (_uploading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Încarcă CSV
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>
        </MudItem>
    </MudGrid>
</MudPaper>

<!-- Reviews Table -->
<MudPaper Class="pa-4" Elevation="2">
    <MudTable Items="_reviews" Hover="true" Striped="true" Dense="true"
              Filter="FilterFunc" Loading="_loading"
              LoadingProgressColor="Color.Primary">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Lista Recenziilor</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString"
                          Placeholder="Caută..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<ReviewModel, object>(x => x.CreatedAt)">Data</MudTableSortLabel></MudTh>
            <MudTh>Conținut</MudTh>
            <MudTh>Autor</MudTh>
            <MudTh>Sursa</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<ReviewModel, object>(x => x.Rating ?? 0)">Rating</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<ReviewModel, object>(x => x.SentimentLabel ?? string.Empty)">Sentiment</MudTableSortLabel></MudTh>
            <MudTh>Scor</MudTh>
            <MudTh>Acțiuni</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Data">@context.CreatedAt.ToString("dd MMM yyyy")</MudTd>
            <MudTd DataLabel="Conținut">
                <MudText Typo="Typo.body2">@(context.Content.Length > 100 ? context.Content[..100] + "..." : context.Content)</MudText>
            </MudTd>
            <MudTd DataLabel="Autor">@(context.AuthorName ?? "Anonim")</MudTd>
            <MudTd DataLabel="Sursa">@context.Source</MudTd>
            <MudTd DataLabel="Rating">
                @if (context.Rating.HasValue)
                {
                    @for (int i = 1; i <= 5; i++)
                    {
                        var star = i;
                        <MudIcon Icon="@(star <= context.Rating.Value ? Icons.Material.Filled.Star : Icons.Material.Outlined.Star)"
                                 Style="font-size:16px;"
                                 Color="@(star <= context.Rating.Value ? Color.Warning : Color.Default)" />
                    }
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Sentiment">
                <MudChip T="string"
                         Color="@(context.SentimentLabel == "Positive" ? Color.Success : context.SentimentLabel == "Negative" ? Color.Error : Color.Default)"
                         Size="Size.Small">
                    @(context.SentimentLabel ?? "N/A")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Scor">@((context.SentimentScore ?? 0).ToString("P0"))</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="@(() => DeleteReview(context.Id))" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    [Inject] private IApiService ApiService { get; set; } = null!;
    [Inject] private StateContainer State { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    [Inject] private IJSRuntime JS { get; set; } = null!;

    private List<ReviewModel> _reviews = new();
    private bool _loading = true;
    private bool _submitting;
    private bool _uploading;
    private string _searchString = string.Empty;
    
    // Scraper options
    private string _source = "Google";
    private string _sortBy = "newest";
    private int _maxCount = 20;

    protected override async Task OnInitializedAsync()
    {
        await LoadReviews();
    }

    private async Task LoadReviews()
    {
        _loading = true;

        if (State.ActiveBusinessProfileId is not null)
        {
            try
            {
                _reviews = await ApiService.GetReviewsAsync(State.ActiveBusinessProfileId.Value);
            }
            catch (Exception)
            {
                Snackbar.Add("Nu s-au putut încărca recenziile.", Severity.Error);
            }
        }

        _loading = false;
    }

    private async Task RunScraper()
    {
        if (State.ActiveBusinessProfileId is null || State.CurrentProfile is null)
        {
            Snackbar.Add("Trebuie să ai un profil activ pentru a folosi scraper-ul.", Severity.Warning);
            return;
        }

        // Verificăm dacă URL-ul este configurat pentru sursa selectată
        var url = _source == "Google" ? State.CurrentProfile.GoogleMapsUrl : State.CurrentProfile.TripAdvisorUrl;
        
        if (string.IsNullOrWhiteSpace(url))
        {
            Snackbar.Add($"Nu ai configurat URL-ul pentru {_source} în Setări!", Severity.Error);
            return;
        }

        _submitting = true;

        try
        {
            var result = await ApiService.ScrapeAndImportAsync(
                State.ActiveBusinessProfileId.Value, _source, _sortBy, _maxCount);

            if (result.NewCount > 0)
            {
                Snackbar.Add($"Succes: Am importat și analizat {result.NewCount} recenzii noi!", Severity.Success);
                await LoadReviews(); // Reîncărcăm lista
            }
            else
            {
                Snackbar.Add("Nu au fost găsite recenzii noi.", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Eroare scraping: {ex.Message}", Severity.Error);
        }

        _submitting = false;
    }

    private async Task DownloadTemplate()
    {
        var fileName = "AISA_Template_Recenzii.csv";
        var content = "Textul Recenziei,Nume Autor,Sursa,Data,Rating (1-5)\n" +
                      "\"Mâncarea a fost excelentă, recomand!\",\"Ion Popescu\",\"Manual\",\"2023-10-25\",5\n" +
                      "\"Serviciu ok, dar așteptare mare.\",\"Maria I.\",\"Manual\",\"2023-11-02\",3";
        
        await JS.InvokeVoidAsync("BlazorDownloadFile", fileName, content);
    }

    private async Task UploadCsv(IBrowserFile file)
    {
        if (State.ActiveBusinessProfileId is null)
        {
            Snackbar.Add("Selectează un profil de business activ.", Severity.Warning);
            return;
        }

        if (file is null) return;

        _uploading = true;
        try
        {
            var message = await ApiService.ImportCsvAsync(State.ActiveBusinessProfileId.Value, file);
            Snackbar.Add(message, Severity.Success);
            await LoadReviews(); // refresh
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _uploading = false;
            StateHasChanged();
        }
    }

    private async Task DeleteReview(Guid id)
    {
        try
        {
            await ApiService.DeleteReviewAsync(id);
            _reviews.RemoveAll(r => r.Id == id);
            Snackbar.Add("Recenzie ștearsă.", Severity.Info);
        }
        catch (Exception)
        {
            Snackbar.Add("Eroare la ștergerea recenziei.", Severity.Error);
        }
    }

    private bool FilterFunc(ReviewModel review)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        return review.Content.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || (review.AuthorName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            || review.Source.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    }
}
