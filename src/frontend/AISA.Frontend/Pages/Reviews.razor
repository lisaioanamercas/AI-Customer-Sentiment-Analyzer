@page "/reviews"
@inherits Fluxor.Blazor.Web.Components.FluxorComponent

<PageTitle>Reviews — AISA</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.RateReview" Class="mr-2" /> Review Inbox
</MudText>

<!-- AI Analysis Panel -->
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-4" Align="Align.Center">AI Sentiment Analysis</MudText>
    <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="4">
        <MudNumericField @bind-Value="_analyzeCount"
                         Label="Reviews to Analyze"
                         Variant="Variant.Outlined"
                         Min="1" Max="100"
                         Style="width:260px;"
                         HelperText="Only unanalyzed reviews" />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Style="height:56px; min-width:200px;"
                   StartIcon="@Icons.Material.Filled.Psychology"
                   OnClick="RunAnalysis"
                   Disabled="ReviewState.Value.IsAnalyzing">
            @if (ReviewState.Value.IsAnalyzing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Analyzing...</span>
            }
            else
            {
                <span>Analyze Reviews</span>
            }
        </MudButton>
    </MudStack>
</MudPaper>

<!-- Import Manual CSV Panel -->
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-3">Import Manual (CSV)</MudText>
    <MudGrid>
        <MudItem xs="12" sm="8" Class="d-flex align-center">
            <MudText Typo="Typo.body2" Class="mr-4">
                Import reviews from a CSV file with columns: <b>Review Text, Author Name, Source, Date, Rating (1-5)</b>.
            </MudText>
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="DownloadTemplate" StartIcon="@Icons.Material.Filled.Download">
                Download Template
            </MudButton>
        </MudItem>
        <MudItem xs="12" sm="4" Class="d-flex align-end justify-end">
            <MudFileUpload T="IBrowserFile" FilesChanged="UploadCsv" Accept=".csv" Disabled="_uploading">
                <ActivatorContent>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               Disabled="_uploading">
                        @if (_uploading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Upload CSV
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>
        </MudItem>
    </MudGrid>
</MudPaper>

<!-- Reviews Table -->
<MudPaper Class="pa-4" Elevation="2">
    <MudTable Items="ReviewState.Value.Reviews" Hover="true" Striped="true" Dense="true"
              Filter="FilterFunc" Loading="ReviewState.Value.IsLoading"
              LoadingProgressColor="Color.Primary">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Reviews List</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString"
                          Placeholder="Search..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<ReviewModel, object>(x => x.CreatedAt)">Date</MudTableSortLabel></MudTh>
            <MudTh>Content</MudTh>
            <MudTh>Author</MudTh>
            <MudTh>Source</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<ReviewModel, object>(x => x.Rating ?? 0)">Rating</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<ReviewModel, object>(x => x.SentimentLabel ?? string.Empty)">Sentiment</MudTableSortLabel></MudTh>
            <MudTh>Score</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Data">@context.CreatedAt.ToString("dd MMM yyyy")</MudTd>
            <MudTd DataLabel="Conținut">
                <MudText Typo="Typo.body2">@(context.Content.Length > 100 ? context.Content[..100] + "..." : context.Content)</MudText>
            </MudTd>
            <MudTd DataLabel="Autor">@(context.AuthorName ?? "Anonim")</MudTd>
            <MudTd DataLabel="Sursa">@context.Source</MudTd>
            <MudTd DataLabel="Rating">
                @if (context.Rating.HasValue)
                {
                    @for (int i = 1; i <= 5; i++)
                    {
                        var star = i;
                        <MudIcon Icon="@(star <= context.Rating.Value ? Icons.Material.Filled.Star : Icons.Material.Outlined.Star)"
                                 Style="font-size:16px;"
                                 Color="@(star <= context.Rating.Value ? Color.Warning : Color.Default)" />
                    }
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Sentiment">
                <MudChip T="string"
                         Color="@(context.SentimentLabel == "Positive" ? Color.Success : context.SentimentLabel == "Negative" ? Color.Error : Color.Default)"
                         Size="Size.Small">
                    @(context.SentimentLabel ?? "N/A")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Scor">@((context.SentimentScore ?? 0).ToString("P0"))</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="@(() => DeleteReview(context.Id))" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    [Inject] private IState<AuthState> AuthState { get; set; } = null!;
    [Inject] private IState<ReviewState> ReviewState { get; set; } = null!;
    [Inject] private IDispatcher Dispatcher { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    [Inject] private IApiService ApiService { get; set; } = null!;
    [Inject] private IJSRuntime JS { get; set; } = null!;

    private bool _uploading;
    private string _searchString = string.Empty;

    // AI Analysis options
    private int _analyzeCount = 20;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        LoadReviews();
    }

    private void LoadReviews()
    {
        if (AuthState.Value.BusinessProfileId.HasValue)
        {
            Dispatcher.Dispatch(new FetchReviewsAction(AuthState.Value.BusinessProfileId.Value));
        }
    }

    private void RunAnalysis()
    {
        if (!AuthState.Value.BusinessProfileId.HasValue)
        {
            Snackbar.Add("Please select an active business profile.", Severity.Warning);
            return;
        }

        Dispatcher.Dispatch(new AnalyzeReviewsAction(AuthState.Value.BusinessProfileId.Value, _analyzeCount));
        Snackbar.Add("Analysis started...", Severity.Info);
    }

    private async Task DownloadTemplate()
    {
        var fileName = "AISA_Template_Recenzii.csv";
        var content = "Textul Recenziei,Nume Autor,Sursa,Data,Rating (1-5)\n" +
                      "\"Mâncarea a fost excelentă, recomand!\",\"Ion Popescu\",\"Manual\",\"2023-10-25\",5\n" +
                      "\"Serviciu ok, dar așteptare mare.\",\"Maria I.\",\"Manual\",\"2023-11-02\",3";
        
        await JS.InvokeVoidAsync("BlazorDownloadFile", fileName, content);
    }

    private async Task UploadCsv(IBrowserFile file)
    {
        if (!AuthState.Value.BusinessProfileId.HasValue)
        {
            Snackbar.Add("Selectează un profil de business activ.", Severity.Warning);
            return;
        }

        if (file is null) return;

        _uploading = true;
        try
        {
            var message = await ApiService.ImportCsvAsync(AuthState.Value.BusinessProfileId.Value, file);
            Snackbar.Add(message, Severity.Success);
            LoadReviews(); // refresh
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _uploading = false;
        }
    }

    private void DeleteReview(Guid id)
    {
        Dispatcher.Dispatch(new DeleteReviewAction(id));
        Snackbar.Add("Review deletion requested.", Severity.Info);
    }

    private bool FilterFunc(ReviewModel review)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        return review.Content.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || (review.AuthorName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            || review.Source.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    }
}
